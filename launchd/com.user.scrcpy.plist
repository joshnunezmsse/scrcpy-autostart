<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.scrcpy</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/REPLACE_WITH_USER/Library/Application Support/scrcpy-autostart/scrcpy-trigger.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/scrcpy-trigger.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/scrcpy-trigger.err</string>
</dict>
</plist>